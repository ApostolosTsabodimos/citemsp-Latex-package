\NeedsTeXFormat{LaTeX2e}[2020/10/01]
\ProvidesPackage{citemsp}[2026/04/28 v2.2 Per-key citation locators (biblatex or natbib)]

% ── Backend detection ────────────────────────────────────────────────────────
%  citemsp can sit on top of either biblatex or natbib. Whichever is loaded
%  first wins; if both are loaded (which itself would be an error), biblatex
%  is preferred.
\newif\if@citesp@biblatex
\newif\if@citesp@natbib
\@ifpackageloaded{biblatex}
  {\@citesp@biblatextrue}
  {\@ifpackageloaded{natbib}
     {\@citesp@natbibtrue}
     {\PackageError{citemsp}
        {Either biblatex or natbib must be loaded before citemsp}
        {Load \string\usepackage{biblatex} or \string\usepackage{natbib}
         (or use a class such as revtex4-2 that loads natbib automatically)
         before \string\usepackage{citemsp}.}}}

\RequirePackage{graphicx}   % \scalebox
\RequirePackage{amssymb}    % \square (□ glyph for box locators)
\RequirePackage{etoolbox}   % \forcsvlist (biblatex pulls it; natbib does not)

% ── User-configurable sizing ──────────────────────────────────────────────────
\newcommand{\citemspscale}{0.35}
\newcommand{\citesize}[1]{\scalebox{\citemspscale}{#1}}

% ── Internal state ────────────────────────────────────────────────────────────
\newcommand{\@citesp@sec}{}
\newcommand{\@citesp@par}{}
\def\@citesp@itshape{it}%

% ── Hyperref-aware spacing and link wrapper ──────────────────────────────────
%  \@citesp@hrefkern : tiny kern after the bracketed number when hyperref is
%                     loaded without colorlinks (so the bracket doesn't kiss
%                     the locator subscript).
%  \@citesp@linkwrap : on the natbib path, wraps the printed number in a
%                     hyperref jump to the bibliography entry. On the biblatex
%                     path, biblatex's own \bibhyperref is used instead, so
%                     this stays as identity.
\def\@citesp@hrefkern{}
\def\@citesp@linkwrap#1#2{#2}
\AtBeginDocument{%
  \@ifpackageloaded{hyperref}{%
    \ifHy@colorlinks\else
      \def\@citesp@hrefkern{\kern1.5pt}%
    \fi
    \if@citesp@natbib
      \def\@citesp@linkwrap#1#2{\hyperlink{cite.#1}{#2}}%
    \fi
  }{}%
}

% ── Prefix registry ──────────────────────────────────────────────────────────
\newcommand{\citemspprefix}[2]{%
  \expandafter\def\csname @citesp@pfx@#1\endcsname{#2}%
}

\citemspprefix{b}{\ensuremath{\square}}%            box         □<num>
\citemspprefix{d}{\ensuremath{\triangleq}}%         definition  ≜<num>
\citemspprefix{e}{eq.}%                              equation    eq.<num>
\citemspprefix{f}{\ensuremath{\boxdot}}%            figure      ⊡<num>
\citemspprefix{n}{\ensuremath{\dagger}}%            footnote    †<num>
\citemspprefix{p}{pp.}%                              page        pp.<num>
\citemspprefix{t}{\ensuremath{\boxplus}}%           table       ⊞<num>

% ── Locator type dispatch ─────────────────────────────────────────────────────
\def\@citesp@renderloc#1#2{%
  \expandafter\@citesp@dispatchloc#1\@citesp@end{#2}%
}
\def\@citesp@dispatchloc#1#2\@citesp@end#3{%
  \ifcsname @citesp@pfx@#1\endcsname
    \csname @citesp@pfx@#1\endcsname\kern1pt#2%
  \else
    #3\kern1pt#1#2%
  \fi
}

% ── Locator-rendering body (backend-independent) ─────────────────────────────
%  Emits the super/subscript locator pair for the current \@citesp@sec /
%  \@citesp@par. Called immediately after the citation number is printed.
\newcommand{\@citesp@renderlocators}{%
  \ifx\f@shape\@citesp@itshape
    \def\@citesp@supkern{\mkern2mu}%
    \def\@citesp@subkern{\mkern-1mu}%
  \else
    \def\@citesp@supkern{}%
    \def\@citesp@subkern{}%
  \fi
  \ifx\@citesp@sec\empty
    \ifx\@citesp@par\empty\else
      \@citesp@hrefkern
      \ensuremath{\mbox{}_{\@citesp@subkern\citesize{\@citesp@renderloc{\@citesp@par}{\textparagraph}}}}%
    \fi
  \else
    \@citesp@hrefkern
    \ifx\@citesp@par\empty
      \raisebox{1.5pt}{\ensuremath{\mbox{}^{\@citesp@supkern\citesize{\@citesp@renderloc{\@citesp@sec}{\textsection}}}}}%
    \else
      \raisebox{1.5pt}{\ensuremath{\mbox{}^{\@citesp@supkern\citesize{\@citesp@renderloc{\@citesp@sec}{\textsection}}}_{\@citesp@subkern\citesize{\@citesp@renderloc{\@citesp@par}{\textparagraph}}}}}%
    \fi
  \fi
}

% ── Backend-specific cite command ────────────────────────────────────────────
%  \citelinksp{<single-key>} prints the citation number (linked) followed by
%  the locator super/subscripts. The list-and-bracket handling lives in
%  \citemsp below; here we only handle one key.
\if@citesp@biblatex
  \DeclareCiteCommand{\citelinksp}
    {}
    {\bibhyperref{\printfield{labelnumber}}\@citesp@renderlocators}
    {}
    {}
\else
  \newcommand{\citelinksp}[1]{%
    \@citesp@linkwrap{#1}{\citenum{#1}}%
    \@citesp@renderlocators
  }
\fi

% ── User command ──────────────────────────────────────────────────────────────
% \citemsp{key1/sec/par, key2/sec, key3}
\newcounter{citemspidx}
\newcommand{\citemsp}[1]{%
  [%
  \setcounter{citemspidx}{0}%
  \forcsvlist{\@citemsp@item}{#1}%
  ]%
}
\newcommand{\@citemsp@item}[1]{%
  \ifnum\value{citemspidx}>0 ,\,\fi
  \stepcounter{citemspidx}%
  \@citemsp@parse#1///\@nil
}
\def\@citemsp@parse#1/#2/#3/#4\@nil{%
  \def\@citesp@sec{#2}%
  \def\@citesp@par{#3}%
  \citelinksp{#1}%
}

\endinput
